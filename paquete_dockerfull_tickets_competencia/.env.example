# PostgreSQL
POSTGRES_DB=tickets_db
POSTGRES_USER=tickets_user
POSTGRES_PASSWORD=tickets_pass
POSTGRES_PORT=5432

# Backend
APP_NAME=Sistema Tickets Competencia - Dockerfull
APP_ENV=docker
APP_PORT=8000
DEMO_AUTH_ENABLED=true
DATABASE_URL=postgresql+psycopg2://tickets_user:tickets_pass@db:5432/tickets_db
STORAGE_ROOT=/app/storage/files
INBOUND_PATH=/app/data/inbound
ARCHIVE_PATH=/app/data/inbound/ARCHIVE
ERROR_PATH=/app/data/inbound/ERROR
MAX_UPLOAD_BYTES=15728640
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png

# Frontend
VITE_API_BASE_URL=/api/v1
FRONTEND_PORT=8080
